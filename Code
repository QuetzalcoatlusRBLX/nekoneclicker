<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neko Clicker</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:linear-gradient(#bdefff,#8fdcff);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.game{
    text-align:center;
}

h1{
    color:white;
    text-shadow:2px 2px 5px black;
    margin-bottom:10px;
}

#score{
    font-size:30px;
    color:white;
    margin-bottom:20px;
    font-weight:bold;
}

#neko{
    width:280px;
    cursor:pointer;
    transition:.08s;
    user-select:none;
}

#neko:active{
    transform:scale(.92);
}

.plus{
    position:absolute;
    color:gold;
    font-weight:bold;
    font-size:28px;
    animation:float .8s forwards;
    pointer-events:none;
}

@keyframes float{
    from{
        opacity:1;
        transform:translateY(0);
    }
    to{
        opacity:0;
        transform:translateY(-60px);
    }
}
</style>
</head>
<body>

<div class="game">
    <h1>🐱 Neko Clicker</h1>
    <div id="score">Neko Points: 0</div>

    <!-- Put your image in the same folder -->
    <img src="https://cdn.discordapp.com/attachments/1136904354100690944/1525669576468070600/Head.png?ex=6a543a04&is=6a52e884&hm=34089b46c537de31a6ed1deb36b370cc1da5640b6627c55105b30d5cb99635e2&" id="neko">
</div>
<script>
let score = 0;

const neko = document.getElementById("neko");
const scoreText = document.getElementById("score");
const clickSound = document.getElementById("clickSound");

neko.onclick = function(e){

score++;
scoreText.innerHTML = "Neko Points: " + score;

// Play click sound
clickSound.currentTime = 0;
clickSound.play();

// Click animation
neko.style.transform = "scale(0.9)";
setTimeout(() => {
neko.style.transform = "scale(1)";
}, 60);

// Floating +1
let plus = document.createElement("div");
plus.className = "plus";
plus.innerHTML = "+1";

plus.style.left = e.pageX + "px";
plus.style.top = e.pageY + "px";

document.body.appendChild(plus);

setTimeout(() => {
plus.remove();
}, 800);
}
</script>

</body>
</html>